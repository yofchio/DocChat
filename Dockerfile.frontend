# Monorepo: build context is repository root (same as Dockerfile.api).
FROM node:22-alpine

WORKDIR /app

COPY frontend/package.json frontend/package-lock.json* ./
RUN npm ci

COPY frontend/ .

# API origin for Vite preview proxy (/api -> backend). Override at runtime on Railway.
ARG API_BASE_URL=http://127.0.0.1:5055
ENV API_BASE_URL=${API_BASE_URL}

RUN npm run build

EXPOSE 3000

CMD ["npm", "run", "preview"]
